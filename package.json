{
  "name": "curerays-cws",
  "version": "0.1.0",
  "private": true,
  "description": "CureRays Clinical Workflow System frontend.",
  "engines": {
    "node": ">=18.17 <21",
    "npm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:phase0": "node scripts/phase0-guardrails.mjs",
    "test:phase1": "node scripts/phase1-operational-visibility.mjs",
    "test:phase2": "node scripts/phase2-patient-registration.mjs",
    "test:routes": "node scripts/route-smoke.mjs",
    "test:fraction-worksheet": "node scripts/fraction-worksheet-fixtures.mjs",
    "test:hipaa": "node scripts/hipaa-guardrails.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test:phase0 && npm run test:hipaa && TMPDIR=/tmp npm run test:fraction-worksheet && npm run test:routes && npm run test:phase1 && npm run test:phase2 && npm run build"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "echarts": "^6.1.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.16",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
